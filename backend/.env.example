# App
DEBUG=false
ENV=development

# MongoDB
# Default: mongodb://localhost:27017 (development), set for Atlas or remote in production.
MONGODB_URI=mongodb://localhost:27017
# Optional. If unset: botc_codex_dev when ENV=development, botc_codex when ENV=production.
# MONGODB_DB_NAME=botc_codex_dev

# Auth / JWT
# REQUIRED in production: set a long, random secret (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-in-production-use-a-strong-random-secret
# Token lifetimes (optional – shown here with their defaults)
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7

# Cookies
# Development (Vite proxy or same-origin): keep defaults below.
# Production (HTTPS, cross-origin): set COOKIE_SECURE=true and COOKIE_SAMESITE=none.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Resend (feedback email notifications)
# Get an API key at https://resend.com — required for admin email alerts on feedback submissions.
RESEND_API_KEY=re_your_api_key_here
# The email address to receive feedback notifications.
ADMIN_EMAIL=you@example.com
# The "from" address for outgoing feedback emails. Must be from a Resend-verified domain.
# Format: "Display Name <sender@your-verified-domain.com>" or just "sender@your-verified-domain.com"
RESEND_FROM_EMAIL=updates@your-verified-domain.com
