# App
DEBUG=false
ENV=development

# MongoDB
# Default: mongodb://localhost:27017 (development), set for Atlas or remote in production.
MONGODB_URI=mongodb://localhost:27017
# Optional. If unset: botc_codex_dev when ENV=development, botc_codex when ENV=production.
# MONGODB_DB_NAME=botc_codex_dev

# Auth / JWT
# REQUIRED in production: set a long, random secret (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-in-production-use-a-strong-random-secret
# Token lifetimes (optional – shown here with their defaults)
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (production)
# Comma-separated origins that may call the API (e.g. your Vercel app). Required for Render + Vercel.
# CORS_ORIGINS=https://yourapp.vercel.app,https://www.yourdomain.com

# Cookies
# Development (Vite proxy or same-origin): keep defaults below.
# Production (HTTPS, cross-origin): set COOKIE_SECURE=true and COOKIE_SAMESITE=none.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Gmail SMTP (feedback email notifications) — no custom domain required
# 1. Use a Gmail account that will SEND the notifications.
# 2. Enable 2-Step Verification: Google Account → Security → 2-Step Verification.
# 3. Create an App Password: Security → 2-Step Verification → App passwords → Generate (choose "Mail").
# 4. Copy the 16-character password below (no spaces).
GMAIL_USER=your.gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Email that RECEIVES feedback notifications (can be same as GMAIL_USER or any other address).
ADMIN_EMAIL=you@example.com
